{# Vendor hub: site/hifi/data-sources/<vendor>.html — depth-1 path.
   Driven entirely by the vendor metadata block + the manifest groups. #}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{ vendor_label }} · Gridflow</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..600,30..100&family=Inter:wght@300..600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../assets/theme.css" />
</head>
<body data-page="vendor" data-root="../" data-screen-label="Vendor · {{ vendor_label }}">

  {# ═══════════ HERO ═══════════ #}
  <section class="block" style="padding: 48px 0 40px;">
    <div class="container">
      <div class="crumbs">
        <a href="../index.html">Gridflow</a>
        <span class="sep">/</span>
        <a href="../data-sources.html">Data sources</a>
        <span class="sep">/</span>
        <span class="here">{{ vendor_label }}</span>
      </div>

      <div style="display:grid; grid-template-columns: 1.4fr 1fr; gap: 64px; align-items: end;">
        <div>
          <div class="row gap-8 mb-16" style="align-items:center;">
            <span class="eyebrow">Vendor · {{ vendor_meta.region }} · {{ vendor_meta.domain }}</span>
            <span class="chip" style="font-size: 11px;">Illustrative snapshot</span>
          </div>
          <h1 class="display-2" style="margin-bottom: 18px;">
            {{ vendor_meta.heading_prefix }} <span class="italic">{{ vendor_meta.heading_italic }}</span>
          </h1>
          <p class="lede" style="max-width: 560px;">{{ vendor_meta.lede }}</p>
          <div class="row gap-16 mt-32">
            <a href="#datasets" class="btn primary">Browse {{ manifest_total }} dataset{{ '' if manifest_total == 1 else 's' }} ↓</a>
            {% if vendor_meta.vendor_docs_url %}
              <a href="{{ vendor_meta.vendor_docs_url }}" target="_blank" rel="noopener" class="btn ghost">Vendor docs ↗</a>
            {% endif %}
          </div>
        </div>

        <div>
          <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--rule); background: var(--paper-card);">
            <div style="padding: 18px 20px; border-right: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
              <div class="tiny mb-8">BASE URL</div>
              <div class="mono small" style="word-break: break-all;">{{ vendor_meta.base_url }}</div>
            </div>
            <div style="padding: 18px 20px; border-bottom: 1px solid var(--rule);">
              <div class="tiny mb-8">AUTH</div>
              <div class="small">{{ vendor_meta.auth }}</div>
            </div>
            <div style="padding: 18px 20px; border-right: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
              <div class="tiny mb-8">RATE LIMIT</div>
              <div class="small">{{ vendor_meta.rate_limit }}</div>
            </div>
            <div style="padding: 18px 20px; border-bottom: 1px solid var(--rule);">
              <div class="tiny mb-8">FORMAT</div>
              <div class="small">{{ vendor_meta.format }}</div>
            </div>
            <div style="padding: 18px 20px; border-right: 1px solid var(--rule);">
              <div class="tiny mb-8">EARLIEST</div>
              <div class="small">{{ vendor_meta.earliest }}</div>
            </div>
            <div style="padding: 18px 20px;">
              <div class="tiny mb-8">TIMEZONE</div>
              <div class="small">{{ vendor_meta.timezone }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {# ═══════════ STATS STRIP ═══════════ #}
  <div class="container">
    <div class="stats-strip" style="grid-template-columns: repeat(4, 1fr);">
      <div>
        <div class="stat-n">{{ manifest_total }}</div>
        <div class="stat-l">Dataset{{ '' if manifest_total == 1 else 's' }}</div>
      </div>
      <div>
        <div class="stat-n">{{ manifest.groups | length }}</div>
        <div class="stat-l">Categor{{ 'y' if manifest.groups | length == 1 else 'ies' }}</div>
      </div>
      <div>
        <div class="stat-n">{{ vendor_meta.stat_three_value }}</div>
        <div class="stat-l">{{ vendor_meta.stat_three_label }}</div>
      </div>
      <div>
        <div class="stat-n">{{ vendor_meta.stat_four_value }}</div>
        <div class="stat-l">{{ vendor_meta.stat_four_label }}</div>
      </div>
    </div>
  </div>

  {# ═══════════ DATASETS ═══════════ #}
  <section class="block" id="datasets" style="background: var(--paper-deep); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
    <div class="container">
      <div class="row between mb-32" style="align-items: end;">
        <div>
          <div class="eyebrow mb-8">{{ manifest_total }} dataset{{ '' if manifest_total == 1 else 's' }} · {{ manifest.groups | length }} categor{{ 'y' if manifest.groups | length == 1 else 'ies' }}</div>
          <h2 class="display-3">The catalog.</h2>
        </div>
      </div>

      {% for group in manifest.groups %}
        <div class="mb-32">
          <div class="row between mb-16" style="align-items: baseline;">
            <h3 style="font-family: var(--serif); font-size: 24px;">{{ group.name }}</h3>
            <span class="small">{{ group.datasets | length }} dataset{{ '' if group.datasets | length == 1 else 's' }}</span>
          </div>
          <p class="small mb-24" style="max-width:640px; color:var(--ink-soft);">{{ group.blurb }}</p>

          <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 12px;">
            {% for ds in group.datasets %}
              <a href="{{ vendor_id }}/{{ ds.id }}.html" class="row-link card flush" style="border:1px solid var(--rule); padding: 20px 22px; background: var(--paper-card); display:block;">
                <div class="row between" style="align-items: flex-start; margin-bottom: 12px;">
                  <div>
                    <div class="row gap-8 mb-8">
                      <span class="mono small" style="color:var(--ink-strong);">{{ ds.id }}</span>
                      <span class="chip" style="font-size:10px;">{{ ds.freq }}</span>
                    </div>
                    <h4 style="font-family: var(--serif); font-size: 18px; margin: 0;">{{ ds.title }}</h4>
                  </div>
                  <span class="arrow" aria-hidden="true">→</span>
                </div>
                <div class="row gap-16 small" style="color:var(--ink-soft);">
                  <span><span class="mono">{{ ds.freq }}</span></span>
                  <span>Lag <span class="mono">{{ ds.lag }}</span></span>
                  <span><span class="mono">{{ ds.rows }}</span></span>
                </div>
              </a>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
  </section>

  {# ═══════════ FOOTER NOTE ═══════════ #}
  <section class="block tight">
    <div class="container">
      <p class="small" style="max-width:680px; color:var(--ink-soft);">
        Pages are regenerated from the
        <a href="https://github.com/EBentham/gridflow" target="_blank" rel="noopener" class="link">gridflow</a>
        ETL pipeline's vault content via <code class="mono">gridflow-build</code>. Schemas align with
        <code class="mono">gridflow.schemas.{{ vendor_id }}</code>; values shown in charts are illustrative
        deterministic snapshots, not live {{ vendor_label }} responses.
      </p>
    </div>
  </section>

  <script src="../assets/charts.js"></script>
  <script src="../assets/site.js"></script>
</body>
</html>
