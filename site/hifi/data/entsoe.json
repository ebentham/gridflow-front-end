        { "id": "actual_generation",   "title": "Actual generation per production type (A75/A16)", "freq": "15-60 min", "lag": "T+1 h to T+24 h", "rows": "~17 TS / zone / day" },
        { "id": "generation_forecast", "title": "Day-ahead generation forecast (A65)",             "freq": "hourly",    "lag": "D-1 ~18:00 UTC",  "rows": "1 TS / zone / day" },
        { "id": "wind_solar_forecast", "title": "Wind & solar generation forecast (A69)",          "freq": "hourly",    "lag": "D-1",             "rows": "~3 TS / zone / day" },
        { "id": "installed_capacity",  "title": "Installed generation capacity (A68)",             "freq": "annual",    "lag": "year boundary",   "rows": "~20 TS / zone / year" },
        { "id": "actual_generation_units",      "title": "Actual generation per unit (A73/A16)",       "freq": "hourly", "lag": "T+1 h",         "rows": "varies — many zones empty" },
        { "id": "installed_capacity_units",     "title": "Installed capacity per unit (A71/A33)",      "freq": "annual", "lag": "year boundary", "rows": "varies — many zones empty" },
        { "id": "generation_units_master_data", "title": "Generation units master data (A95)",         "freq": "static", "lag": "on change",     "rows": "varies by zone" },
        { "id": "water_reservoirs",             "title": "Water reservoirs & hydro storage (A72/A16)", "freq": "weekly", "lag": "weekly",        "rows": "1 / zone / week" }
      ]
    },
    {
      "name": "Prices",
