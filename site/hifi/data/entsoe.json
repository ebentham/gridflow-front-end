        { "id": "load_forecast_monthly", "title": "Load forecast — monthly (A65/A32)",       "freq": "hourly", "lag": "monthly", "rows": "~720 / zone / mo" },
        { "id": "load_forecast_yearly",  "title": "Load forecast — yearly (A65/A33)",        "freq": "hourly", "lag": "annual",  "rows": "8760 / zone / year" },
